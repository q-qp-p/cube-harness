# Path to the Windows 11 Enterprise Evaluation ISO (required for first-time install)
# Download from: https://www.microsoft.com/en-us/evalcenter/evaluate-windows-11-enterprise
# WAA_SETUP_ISO=/path/to/Win11_Eval.iso

# Host directory where the Windows VM disk image (data.qcow2) is stored (default: ~/.cube/waa/storage)
# WAA_VM_STORAGE=~/.cube/waa/storage

# Path to evaluation_examples_windows/ from the WAA repo (required for full benchmark runs)
# WAA_EVAL_EXAMPLES_DIR=/path/to/WindowsAgentArena/src/win-arena-container/client/evaluation_examples_windows

# LLM API key (whichever provider you use — passed through to LiteLLM)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-01
